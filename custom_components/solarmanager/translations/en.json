{
  "config": {
    "step": {
      "user": {
        "title": "Choose connection mode",
        "data": {
          "mode": "Mode"
        },
        "data_description": {
          "mode": "Cloud: full functionality with account. Local: sensors only, no internet required."
        }
      },
      "cloud": {
        "title": "Set up Solarmanager Cloud",
        "data": {
          "email": "Email",
          "password": "Password",
          "sm_id": "System ID (smId)",
          "api_key": "Cloud API key (recommended)"
        },
        "data_description": {
          "sm_id": "The smId of your Solarmanager system from the cloud interface.",
          "api_key": "Cloud API key for modern authentication (recommended). Found in the profile settings under «Cloud API Keys». Create the token without an expiry date, enable all four scopes (read, write, externalOverride:read, externalOverride:write), do NOT enable «Allow renewal». Important: the token is only visible right after creation — copy it immediately!"
        }
      },
      "local": {
        "title": "Set up local connection",
        "data": {
          "host": "IP address / hostname",
          "scheme": "Protocol",
          "api_key": "API key (optional)"
        },
        "data_description": {
          "host": "IP address or hostname of the Solar Manager gateway (e.g. 192.168.1.100).",
          "scheme": "HTTP for unencrypted, HTTPS for encrypted (self-signed certificates are accepted).",
          "api_key": "Optional API key to secure the local connection. Leave empty if no key is configured."
        }
      },
      "reauth_confirm": {
        "title": "Re-authenticate Solarmanager",
        "description": "Update credentials for system **{sm_id}**.\n\nRecommended: API key from profile settings → «Cloud API Keys». Token without expiry date, all four scopes (read, write, externalOverride:read, externalOverride:write), do NOT enable «Allow renewal». The token is only visible right after creation — copy it immediately!\n\nEmpty fields keep the stored values.",
        "data": {
          "email": "Email",
          "password": "Password",
          "api_key": "Cloud API key (recommended)"
        }
      },
      "reconfigure_cloud": {
        "title": "Reconfigure Solarmanager Cloud",
        "description": "Empty fields keep the stored values.",
        "data": {
          "email": "Email",
          "password": "Password",
          "sm_id": "System ID (smId)",
          "api_key": "Cloud API key"
        }
      },
      "reconfigure_local": {
        "title": "Reconfigure local connection",
        "description": "Leave the API key empty to keep the stored key.",
        "data": {
          "host": "IP address / hostname",
          "scheme": "Protocol",
          "api_key": "API key (optional)"
        }
      }
    },
    "error": {
      "auth": "Invalid credentials or API key. Please check and try again.",
      "cannot_connect": "Connection failed. Is the gateway reachable?",
      "unknown": "Unknown error. Please check the logs."
    },
    "abort": {
      "already_configured": "This Solarmanager system is already configured.",
      "reauth_successful": "Re-authentication successful. The integration will be reloaded.",
      "reauth_not_supported": "Local mode does not require re-authentication.",
      "reconfigure_successful": "Reconfiguration successful. The integration will be reloaded."
    }
  },
